          <mxGeometry x="90" y="120" width="280" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p1_iamA" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management;" vertex="1" parent="1">
          <mxGeometry x="200" y="150" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p1_iamA_l" value="IAM ユーザ / ロール" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="160" y="215" width="140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p1_pol" value="Inline/Managed Policy:&#10;  Action: sts:AssumeRole&#10;  Resource: arn:aws:iam::B:role/X" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
