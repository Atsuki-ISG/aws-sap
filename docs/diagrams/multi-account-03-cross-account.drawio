        </mxCell>

        <mxCell id="p2_warn" value="⚠ KMS暗号化されたS3 は「バケットポリシー + KMSキーポリシー + IAMポリシー」の3点セットで許可が必要。&#10;    クロスアカウントで最もハマる落とし穴。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#DD344C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="465" width="920" height="40" as="geometry" />
