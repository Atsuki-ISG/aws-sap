          <mxGeometry x="580" y="435" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p2_bucket_pol" value="バケットポリシー:&#10;  Principal: arn:aws:iam::A:role/R&#10;  Action: s3:GetObject&#10;  Resource: bucket/*" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="700" y="360" width="280" height="70" as="geometry" />
