        <!-- ============ Pattern 3: AWS RAM ============ -->
        <mxCell id="p3_box" value="③ AWS RAM (Resource Access Manager) — インフラリソースを明示的に共有" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;strokeWidth=2;fontSize=14;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="540" width="1480" height="200" as="geometry" />
