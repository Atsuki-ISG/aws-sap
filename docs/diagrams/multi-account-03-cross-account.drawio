        </mxCell>
        <mxCell id="p2_kms_pol" value="キーポリシー (両側必須):&#10;  Principal: arn:aws:iam::A:role/R&#10;  Action: kms:Decrypt / kms:GenerateDataKey&#10;  → 無いと S3 からデータを取り出せない" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#DD344C;fontStyle=1;" vertex="1" parent="1">
