        <mxCell id="pd_arr1_l" value="x-api-key + Bearer" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="945" y="378" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="pd_arr2" style="endArrow=classic;html=1;strokeColor=#DD344C;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="pd_la" target="pd_apigw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pd_arr3" style="endArrow=classic;html=1;strokeColor=#DD344C;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="pd_apigw" target="pd_back">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="pd_text" value="✓ 選定理由: API Key で課金集計 / Usage Plan で プラン別 throttle/quota / WAF で IP制限&#10;⚠ HTTP API/AppSync は API Key + Usage Plan 非対応 → REST API 一択&#10;典型: 公開 SaaS API / 決済/地図/SMS API / マーケットプレイス出品" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="830" y="525" width="690" height="80" as="geometry" />
        </mxCell>

        <!-- ===== Decision Flow ===== -->
        <mxCell id="dec_box" value="🧭 判断フロー — 要件から選ぶ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=1;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="980" height="130" as="geometry" />
        </mxCell>
        <mxCell id="dec_text" value="① クライアントとサーバの双方向通信が必要か？&#10;   YES → API Gateway WebSocket (パターンC) または AppSync Subscription (パターンA)&#10;② オフライン同期 / GraphQL / 1リクエストで複数DSが必要か？&#10;   YES → AppSync (パターンA)&#10;③ B2B でAPI Key + Usage Plan + 細かい契約管理が必要か？&#10;   YES → API Gateway REST (パターンD)&#10;④ それ以外の通常CRUD/RESTか？&#10;   YES → API Gateway HTTP (低コスト/低レイテンシ) ＋ Cognito JWT (パターンB の HTTP版)&#10;   既存REST資産/AWSサービス直接統合/VTLが必要なら REST API" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="80" y="675" width="940" height="90" as="geometry" />
        </mxCell>

        <!-- ===== Selection Matrix ===== -->
        <mxCell id="mat_box" value="📌 サービス選定マトリクス — 要件 → サービス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="640" width="480" height="130" as="geometry" />
        </mxCell>
        <mxCell id="mat_text" value="• オフライン+リアルタイム → AppSync (Ⓐ)&#10;• 標準SPA CRUD/コスト重視 → HTTP API (Ⓑ軽量版)&#10;• AWS直接統合/VTL/WAF → REST API (Ⓑ)&#10;• Server push (チャット/IoT制御) → WebSocket (Ⓒ)&#10;• B2B + Usage Plan/API Key → REST API (Ⓓ)&#10;• MQTT / 大量同接 IoT → IoT Core (図対象外)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1080" y="675" width="450" height="90" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
