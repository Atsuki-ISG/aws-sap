          <mxGeometry x="600" y="120" width="180" height="180" as="geometry" />
        </mxCell>
        <mxCell id="pa_extra_text" value="📌 ポイント&#10;• Subscription で他端末の更新を即時受信&#10;• @auth ディレクティブで&#10;  owner-only 認可&#10;• Conflict Resolution で&#10;  オフライン編集を自動マージ" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;fontColor=#FF9900;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="120" width="180" height="180" as="geometry" />
        </mxCell>

