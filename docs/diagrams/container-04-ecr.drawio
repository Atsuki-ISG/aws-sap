        <!-- Endpoint explanation -->
        <mxCell id="ep_box" value="🧭 必要なエンドポイント 4セット — どれか欠けると pull 失敗" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#3B48CC;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="510" width="660" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ep_text" value="① com.amazonaws.&lt;region&gt;.ecr.api  — Interface EP&#10;     認証トークン取得・リポジトリAPI&#10;② com.amazonaws.&lt;region&gt;.ecr.dkr  — Interface EP&#10;     docker pull / push の registry API&#10;③ com.amazonaws.&lt;region&gt;.s3       — Gateway EP (無料)&#10;     image layer の実体は S3 に格納されているため必須&#10;④ com.amazonaws.&lt;region&gt;.logs     — Interface EP&#10;     awslogs ログドライバを使う場合に必要&#10;&#10;➡ 加えて secretsmanager / ssm を Secrets 注入で使うなら追加。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="900" y="545" width="620" height="140" as="geometry" />
