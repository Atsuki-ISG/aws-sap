        <mxCell id="src_policy" value="リポジトリポリシー&#10;&#10;{ &#10;  &quot;Effect&quot;: &quot;Allow&quot;,&#10;  &quot;Principal&quot;: &quot;*&quot;,&#10;  &quot;Action&quot;: [&#10;    &quot;ecr:GetDownloadUrlForLayer&quot;,&#10;    &quot;ecr:BatchGetImage&quot;,&#10;    &quot;ecr:BatchCheckLayerAvailability&quot;&#10;  ],&#10;  &quot;Condition&quot;: { &quot;StringEquals&quot;: {&#10;    &quot;aws:PrincipalOrgID&quot;: &quot;o-xxxx&quot;&#10;  } }&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;strokeWidth=1;fontSize=10;fontColor=#232F3E;verticalAlign=top;spacingTop=8;align=left;spacingLeft=12;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="240" y="120" width="290" height="220" as="geometry" />
        </mxCell>

        <mxCell id="src_note" value="📌 aws:PrincipalOrgID で組織内全アカウントを一括 Allow&#10;     → アカウント追加時にポリシー更新不要" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=2;fontColor=#3B48CC;" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="450" height="50" as="geometry" />
        </mxCell>

