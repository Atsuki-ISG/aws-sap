        <!-- Selection Decision Tree -->
        <mxCell id="dec_box" value="🧭 RTO/RPO別 戦略選定フロー — 試験で迷ったときの判断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="695" width="1100" height="180" as="geometry" />
        </mxCell>
        <mxCell id="dec_text" value="• RTO 数日 OK ＆ RPO 時間 OK → ① Backup &amp; Restore（コスト最優先）&#10;• RTO 1時間程度 ＆ RPO 数分 → ② Pilot Light（DB だけ常時、APP は停止）&#10;• RTO 数分 ＆ RPO 秒〜分 → ③ Warm Standby（縮小版を常時稼働、即スケール）&#10;• RTO ほぼ0 ＆ RPO ほぼ0 → ④ Multi-Site Active-Active（両系本番、Aurora Global / DynamoDB Global Tables）&#10;&#10;⚠️ 引っかけパターン:&#10;  - 「RPO 0」を要求 → Active-Active 一択（Pilot Light や Warm Standby では達成不可）&#10;  - 「最もコスト効率が良い」＋ RTO 緩い → Backup &amp; Restore&#10;  - 「フェイルオーバー後にスケールアップが必要」→ Pilot Light or Warm Standby（Active-Active は不要）" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="60" y="725" width="1070" height="145" as="geometry" />
        </mxCell>

        <!-- 📌 RTO/RPO Cheat Sheet (right bottom) -->
        <mxCell id="cheat_box" value="📌 RTO/RPO別 戦略選定表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#0D47A1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1160" y="695" width="400" height="180" as="geometry" />
        </mxCell>
        <mxCell id="cheat_text" value="RTO &gt; 24h, RPO &gt; 1h → Backup &amp; Restore&#10;RTO 1〜4h, RPO &lt; 1h → Pilot Light&#10;RTO &lt; 30min, RPO &lt; 5min → Warm Standby&#10;RTO &lt; 1min, RPO &lt; 1s → Multi-Site Active-Active&#10;&#10;💡 暗記カード:&#10;『RPO=0なら Active-Active 必須』&#10;『DR Region で App 停止 = Pilot Light』&#10;『DR Region で App 縮小稼働 = Warm Standby』" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#0D47A1;" vertex="1" parent="1">
