        </mxCell>

        <!-- ====== Migration Hub ====== -->
        <mxCell id="hub_note" value="📌 AWS Migration Hub を司令塔として: Discovery (依存関係可視化) → Assessment (6R判定) → Orchestrator (移行プレイブック実行) → Refactor Spaces (Strangler Fig 支援)。&#10;Aurora Serverless v2 は RDS Blue/Green + DMS CDC で RPO 秒単位・RTO 分単位の切替が可能。停止時間ほぼゼロで DB 移行。" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="745" width="1520" height="45" as="geometry" />
        </mxCell>

        <!-- Bottom-right key takeaway -->
        <mxCell id="key_takeaway" value="📌 ワークロード→サービス選定&#10;未使用=Retire / SaaS可=Repurchase / 急ぎ=Rehost / 部分改修=Replatform / 最適化=Refactor(Lambda/Fargate) / DB=Aurora Serverless v2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#FF9900;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#FFFFFF;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="800" width="1520" height="50" as="geometry" />
