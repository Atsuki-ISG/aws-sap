        <mxCell id="s1_ecs" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ecs;" vertex="1" parent="1">
          <mxGeometry x="100" y="555" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s1_fargate" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.fargate;" vertex="1" parent="1">
          <mxGeometry x="210" y="555" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s1_text" value="• アプリを Docker 化&#10;• EC2 依存排除&#10;• 起動高速化&#10;• Blue/Green 配備&#10;• オブザーバビリティ" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="75" y="615" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Stage 2 -->
        <mxCell id="s2_box" value="Stage 2: API 分解&#10;(BFF + サイドカー)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7AA116;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="325" y="505" width="240" height="210" as="geometry" />
        </mxCell>
        <mxCell id="s2_apigw" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#5294CF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.api_gateway;" vertex="1" parent="1">
          <mxGeometry x="365" y="555" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s2_appmesh" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.app_mesh;" vertex="1" parent="1">
          <mxGeometry x="475" y="555" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s2_text" value="• API Gateway Facade&#10;• 境界別にサービス分離&#10;• サービス間通信 = App Mesh&#10;• 段階リリース (Canary)&#10;• DB は共有のまま" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="340" y="615" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Stage 3 -->
        <mxCell id="s3_box" value="Stage 3: Lambda 置換&#10;(機能別サーバーレス化)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7AA116;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="590" y="505" width="240" height="210" as="geometry" />
        </mxCell>
        <mxCell id="s3_lambda" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" vertex="1" parent="1">
          <mxGeometry x="630" y="555" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3_step" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.step_functions;" vertex="1" parent="1">
          <mxGeometry x="740" y="555" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3_text" value="• 短時間APIは Lambda へ&#10;• 長時間は Step Functions&#10;• コールドスタート対策&#10;  = Provisioned Concurrency&#10;• EventBridge でイベント化" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="605" y="615" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Stage 4 -->
        <mxCell id="s4_box" value="Stage 4: DB モダナイズ&#10;(Aurora Serverless v2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7AA116;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="855" y="505" width="240" height="210" as="geometry" />
        </mxCell>
        <mxCell id="s4_aurora" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#3334B9;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.aurora;" vertex="1" parent="1">
          <mxGeometry x="895" y="555" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s4_ddb" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#3334B9;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;" vertex="1" parent="1">
          <mxGeometry x="1005" y="555" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s4_text" value="• 負荷に応じ ACU 自動伸縮&#10;• Serverless v2 = 0.5〜128 ACU&#10;• 低頻度ワークは DynamoDB&#10;  (単一桁ms / オンデマンド)&#10;• DMS で既存DB 連続レプリ" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="870" y="615" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Stage 5 -->
        <mxCell id="s5_box" value="Stage 5: イベント駆動&#10;(完全疎結合)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7AA116;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="1120" y="505" width="420" height="210" as="geometry" />
        </mxCell>
        <mxCell id="s5_eb" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eventbridge;" vertex="1" parent="1">
          <mxGeometry x="1150" y="555" width="50" height="50" as="geometry" />
