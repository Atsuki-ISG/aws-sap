        <!-- Strangler Fig pattern steps -->
        <mxCell id="sf_steps_box" value="Strangler Fig の実装 5 ステップ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=1;fontSize=12;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="980" height="180" as="geometry" />
        </mxCell>
        <mxCell id="sf_step1" value="① Facade 配置&#10;API Gateway / ALB で&#10;全トラフィックを仲介&#10;ドメインを統一" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;fontSize=10;fontColor=#232F3E;verticalAlign=top;spacingTop=4;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="285" width="180" height="130" as="geometry" />
        </mxCell>
        <mxCell id="sf_step2" value="② 境界特定&#10;ビジネス境界/契約を&#10;明確化、最も変更頻度&#10;の高い機能を選定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;fontSize=10;fontColor=#232F3E;verticalAlign=top;spacingTop=4;align=center;" vertex="1" parent="1">
          <mxGeometry x="275" y="285" width="180" height="130" as="geometry" />
        </mxCell>
        <mxCell id="sf_step3" value="③ 新実装&#10;Lambda/Fargate で&#10;対象機能を書き直し&#10;DBアクセスは共存" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;fontSize=10;fontColor=#232F3E;verticalAlign=top;spacingTop=4;align=center;" vertex="1" parent="1">
          <mxGeometry x="470" y="285" width="180" height="130" as="geometry" />
        </mxCell>
        <mxCell id="sf_step4" value="④ ルーティング切替&#10;Canary/Blue-Green&#10;新版へトラフィック&#10;段階移行 (1%→100%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;fontSize=10;fontColor=#232F3E;verticalAlign=top;spacingTop=4;align=center;" vertex="1" parent="1">
          <mxGeometry x="665" y="285" width="180" height="130" as="geometry" />
        </mxCell>
        <mxCell id="sf_step5" value="⑤ 旧退役&#10;旧コードを物理削除&#10;DBスキーマ分割&#10;次の機能へ反復" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;fontSize=10;fontColor=#232F3E;verticalAlign=top;spacingTop=4;align=center;" vertex="1" parent="1">
          <mxGeometry x="860" y="285" width="170" height="130" as="geometry" />
        </mxCell>

        <!-- ====== 6R 戦略 ====== -->
        <mxCell id="r6_box" value="6R 戦略 — AWS Migration Hub で各アプリの移行方式を判定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF1FF;strokeColor=#3B48CC;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="80" width="480" height="360" as="geometry" />
        </mxCell>

        <mxCell id="mhub_icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.migration_hub;" vertex="1" parent="1">
          <mxGeometry x="1490" y="95" width="40" height="40" as="geometry" />
        </mxCell>

        <mxCell id="r6_rehost" value="🔹 Rehost (Lift &amp; Shift)&#10;そのまま EC2 へ。AWS Application Migration Service (MGN)。速いが最適化なし。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;fontSize=10;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="125" width="440" height="45" as="geometry" />
        </mxCell>
        <mxCell id="r6_replatform" value="🔹 Replatform (Lift &amp; Reshape)&#10;OS/DB を置換 (Oracle→Aurora / Windows→Linux)。中程度の改修。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;fontSize=10;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="175" width="440" height="45" as="geometry" />
        </mxCell>
        <mxCell id="r6_refactor" value="🔹 Refactor / Re-architect&#10;サーバーレス化・マイクロサービス分割。コスト高だが TCO 最小。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;fontSize=10;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="225" width="440" height="45" as="geometry" />
        </mxCell>
        <mxCell id="r6_repurchase" value="🔹 Repurchase (Drop &amp; Shop)&#10;SaaS へ乗り換え (CRM→Salesforce / HR→Workday)。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;fontSize=10;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="275" width="440" height="45" as="geometry" />
        </mxCell>
        <mxCell id="r6_retain" value="🔹 Retain&#10;コンプライアンス/依存関係で現状維持。後回し判定。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;fontSize=10;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="325" width="440" height="45" as="geometry" />
        </mxCell>
        <mxCell id="r6_retire" value="🔹 Retire&#10;利用されていない → 削除 (棚卸しで 10-20% は該当)。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;fontSize=10;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="375" width="440" height="45" as="geometry" />
        </mxCell>

        <!-- ====== 段階移行パス (コンテナ化→サーバーレス) ====== -->
        <mxCell id="path_box" value="段階的モダナイゼーションパス — 小さく始める → 完全サーバーレスへ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F8E8;strokeColor=#7AA116;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="1520" height="270" as="geometry" />
        </mxCell>

        <!-- Stage 1 -->
        <mxCell id="s1_box" value="Stage 1: コンテナ化&#10;(Docker 化 + ECS/Fargate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7AA116;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="505" width="240" height="210" as="geometry" />
