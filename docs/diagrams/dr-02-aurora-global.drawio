          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="280" y="130" />
              <mxPoint x="845" y="130" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="aurora_replica_l" value="🌐 Storage-Level Replication（物理レプリケーション）&#10;典型 &lt; 1秒、最大10ms 程度" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#E7157B;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="105" width="380" height="30" as="geometry" />
        </mxCell>

        <!-- Aurora Global features box -->
        <mxCell id="aurora_features" value="🎯 Aurora Global DB の特徴" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF1FF;strokeColor=#3334B9;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#3334B9;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1000" y="105" width="560" height="280" as="geometry" />
        </mxCell>
        <mxCell id="aurora_features_text" value="• Primary 1 + Secondary 最大 5 リージョン&#10;• 物理レプリケーション (Storage-level) — Read Replica より高速&#10;• RPO &lt; 1秒（典型値）／RTO &lt; 1分（手動 or Managed Failover）&#10;&#10;【フェイルオーバー方法】&#10;  ① Managed Planned Failover — 計画的な切替（無停止に近い）&#10;  ② Detach + Promote — 障害時、Secondary を独立したクラスタへ昇格&#10;  ③ Switchover — 1.4 以降、書き込み継続のまま切替可&#10;&#10;【Write Forwarding (Aurora MySQL のみ)】&#10;  Secondary に書き込み → Primary へ転送 → 結果を Secondary が返す&#10;  ⚠️ レイテンシ大、PostgreSQL 非対応&#10;&#10;💡 試験Tips: 「グローバル読み取り＋書き込み1箇所」「DR目的のクロスリージョンDB」&#10;　 → Aurora Global Database が最適解" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1015" y="135" width="540" height="240" as="geometry" />
        </mxCell>

        <!-- ===== DynamoDB Global Tables Section ===== -->
        <mxCell id="ddb_title" value="② DynamoDB Global Tables — 双方向書き込み（Active-Active）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=15;fontStyle=1;fontColor=#3F8624;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="900" height="28" as="geometry" />
