        <mxCell id="aurora_s1_note" value="📖 読み取り: ローカル低レイテンシ&#10;✏️ Write Forwarding: 書き込みをPrimaryへ自動転送&#10;⏱ レプリ遅延: 通常 &lt; 1秒（典型）" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#7AA116;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="270" width="400" height="100" as="geometry" />
        </mxCell>

