        <mxCell id="ou_wl_note" value="📌 環境別/アプリ別 にアカウントを分離&#10;Blast radius を限定、コスト分割、IAM境界" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#3B48CC;fontStyle=2;" vertex="1" parent="1">
