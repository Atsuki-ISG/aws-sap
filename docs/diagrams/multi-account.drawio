          <mxGeometry x="1340" y="320" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="acc_sb2_label" value="エンジニアB&#10;(個人実験)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1310" y="375" width="110" height="36" as="geometry" />
        </mxCell>

        <mxCell id="ou_sb_note" value="📌 SCPで高額サービス・特定リージョンを禁止&#10;Budgets で月次$100上限を強制" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7AA116;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1030" y="440" width="440" height="40" as="geometry" />
        </mxCell>

        <!-- ===== Bottom: Cross-Account Pattern ===== -->
        <mxCell id="cross_box" value="クロスアカウント アクセスパターン" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=1;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="560" width="1400" height="270" as="geometry" />
        </mxCell>

        <!-- Pattern 1: Assume Role -->
        <mxCell id="p1_title" value="① IAM AssumeRole（プリンシパルが信頼関係でロール引き受け）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#3B48CC;" vertex="1" parent="1">
          <mxGeometry x="120" y="595" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p1_text" value="送信元: IAMユーザー/ロール → STS:AssumeRole&#10;送信先: 信頼ポリシー(誰が)+IAMポリシー(何を)&#10;典型: クロスアカウントS3アクセス、CI/CDからのデプロイ" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="120" y="615" width="380" height="60" as="geometry" />
        </mxCell>

        <!-- Pattern 2: Resource Policy -->
        <mxCell id="p2_title" value="② リソースベースポリシー（リソース側でPrincipal指定）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#7AA116;" vertex="1" parent="1">
          <mxGeometry x="540" y="595" width="500" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p2_text" value="対象: S3バケット/SQS/SNS/KMS/Lambda/Secrets Manager等&#10;典型: S3バケット側で他アカウントのIAMロールを直接Allow&#10;⚠ KMS暗号化: バケット側 + KMSキー側 両方で許可必要" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="540" y="615" width="450" height="60" as="geometry" />
        </mxCell>

        <!-- Pattern 3: AWS RAM -->
        <mxCell id="p3_title" value="③ AWS RAM（インフラリソース共有）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#FF9900;" vertex="1" parent="1">
          <mxGeometry x="1020" y="595" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p3_text" value="対象: VPC Subnet, TGW, Route 53 Resolver Rule,&#10;       License Manager, ECR Repo, Glue Catalog 等&#10;⚠ S3 / DynamoDB は対象外（リソースポリシーを使う）" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1020" y="615" width="460" height="60" as="geometry" />
        </mxCell>

        <!-- Decision Tree -->
        <mxCell id="dec_title" value="🧭 試験で迷ったときの判断フロー" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="120" y="690" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="dec_text" value="• 「OU/アカウント全体に予防的ガードレール」→ SCP（Organizations機能）&#10;• 「クロスアカウントでリソースに直接Allow」→ リソースポリシー（KMSは両側必要）&#10;• 「VPC/TGW/Resolver/Subnet を他アカウントに共有」→ AWS RAM&#10;• 「アカウントを大量に払い出し+標準構成」→ Control Tower Account Factory&#10;• 「外部IdPでSSO」→ IAM Identity Center（旧AWS SSO）+ permission set&#10;• 「AWS横断のCloudTrailログ集約」→ Org Trail（Log Archive アカウントへ）&#10;• 「セキュリティサービスを別アカウントから管理」→ Delegated Administrator (Audit account)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="120" y="710" width="1380" height="115" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
