        <mxCell id="key_takeaway" value="📌 ワークロード→サービス選定&#10;AWSイベント・SaaS = EventBridge / ファンアウト通知・モバイル = SNS / バッファ・デカップル = SQS / 順序+重複不可 = FIFO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#FF9900;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#FFFFFF;verticalAlign=middle;align=center;" vertex="1" parent="1">
