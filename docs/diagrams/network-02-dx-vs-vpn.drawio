        <mxCell id="dx_onprem" value="オンプレ DC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="90" y="140" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- DX Location -->
        <mxCell id="dx_loc" value="DX Location&#10;(キャリアハウス)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=1;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="240" y="140" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- DX icon -->
        <mxCell id="dx_icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.direct_connect;" vertex="1" parent="1">
