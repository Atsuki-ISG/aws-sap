          <mxGeometry x="220" y="260" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Connection arrows -->
        <mxCell id="dx_link1" value="専用線 (1/10/100Gbps)" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#FF9900;strokeWidth=3;fontSize=9;" edge="1" parent="1" source="dx_onprem" target="dx_loc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dx_link2" value="クロスコネクト" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#FF9900;strokeWidth=3;fontSize=9;" edge="1" parent="1" source="dx_loc" target="dx_icon">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dx_link3" value="VIF" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#FF9900;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="dx_icon" target="dx_vpc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- DX features -->
        <mxCell id="dx_features" value="特徴&#10;• 物理専用線 (1/10/100 Gbps)、安定した低レイテンシ&#10;• 帯域保証、ジッター/パケロス少&#10;• データ転送料が VPN/Internet より安い&#10;• セットアップ 数週間〜数ヶ月 (キャリア工事)&#10;• 月額: ポート $300〜、データ転送 $0.02/GB〜&#10;• 単一回線は SLA なし → 冗長化が前提" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="440" height="120" as="geometry" />
        </mxCell>

        <!-- ===== MIDDLE: VPN ===== -->
        <mxCell id="vpn_box" value="Site-to-Site VPN — IPsec / 即時 / 低コスト" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF1FF;strokeColor=#3B48CC;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="480" height="430" as="geometry" />
        </mxCell>

        <!-- Onprem VPN -->
        <mxCell id="vpn_onprem" value="オンプレ DC&#10;(CGW)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="600" y="140" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- Internet -->
        <mxCell id="vpn_inet" value="Internet" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=1;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="750" y="150" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- VPN GW icon -->
        <mxCell id="vpn_icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.site_to_site_vpn;" vertex="1" parent="1">
