          <mxGeometry x="1280" y="425" width="200" height="35" as="geometry" />
        </mxCell>

        <!-- ===== Bottom: OU Design Principles ===== -->
        <mxCell id="design_box" value="OU設計の原則 — どの基準で分離するか？" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=1;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="1480" height="140" as="geometry" />
        </mxCell>

        <mxCell id="design_text" value="• セキュリティ境界 — 監査要件が異なる / 強い分離が必要 → 別OU (例: Security OU vs Workload OU)&#10;• ライフサイクル — 本番/ステージ/開発は影響範囲を限定するため必ず別アカウント (環境別OU か アプリOU内のサブOU)&#10;• 課金/コスト — 部門別/プロジェクト別の請求境界が必要なら別アカウント&#10;• ガバナンス — SCP の適用粒度を揃える単位で OU を切る (同じガードレールが効く範囲)&#10;• 推奨スタート: Security / Infrastructure / Workload (Prod/NonProd) / Sandbox の4本柱 → 必要に応じて子OU で細分化&#10;• アンチパターン: 「部署ごとにOU」「すべてフラット」→ ガバナンスが効かなくなる" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="80" y="520" width="1450" height="105" as="geometry" />
        </mxCell>

        <!-- Decision Tree -->
        <mxCell id="dec_title" value="🧭 試験で迷ったときの判断フロー" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="60" y="650" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="dec_text" value="• 「中央集約ログ」→ Log Archive アカウント + Org Trail&#10;• 「セキュリティサービスを別アカウントから管理」→ Delegated Administrator (Audit account)&#10;• 「アカウント大量払い出し+標準化」→ Control Tower + Account Factory&#10;• 「外部IdP (Azure AD / Okta) でSSO」→ IAM Identity Center + Permission Set&#10;• 「ネットワーク (TGW/VPC) を全社で共有」→ Network/Shared アカウント + AWS RAM&#10;• 「請求はまとめたいが権限は完全分離」→ AWS Organizations の Consolidated Billing + 別OU + SCP" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="60" y="675" width="1480" height="115" as="geometry" />
        </mxCell>

        <!-- Arrows: Org Trail → Log Archive -->
        <mxCell id="arrow_trail_log" style="endArrow=classic;html=1;strokeColor=#232F3E;strokeWidth=2;dashed=1;" edge="1" parent="1" source="orgtrail_box" target="acc_log">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrows: Delegated Admin → Audit -->
        <mxCell id="arrow_dadmin_audit" style="endArrow=classic;html=1;strokeColor=#232F3E;strokeWidth=2;dashed=1;" edge="1" parent="1" source="dadmin_box" target="acc_audit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
