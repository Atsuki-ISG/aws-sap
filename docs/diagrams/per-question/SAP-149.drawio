        <mxCell id="scp_d" value="SCP (組織ルート):&#xa;{&#xa;  &quot;Effect&quot;: &quot;Deny&quot;,&#xa;  &quot;Action&quot;: [&#xa;    &quot;aws-marketplace:Associate*&quot;,&#xa;    &quot;aws-marketplace:Disassociate*&quot;,&#xa;    &quot;aws-marketplace:ModifyPrivateMarketplace&quot;&#xa;  ],&#xa;  &quot;Resource&quot;: &quot;*&quot;,&#xa;  &quot;Condition&quot;: {&#xa;    &quot;StringNotLike&quot;: {&#xa;      &quot;aws:PrincipalArn&quot;:&#xa;        &quot;arn:aws:iam::*:role/ProcurementAdmin&quot;&#xa;    }&#xa;  }&#xa;}" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontStyle=0;fontColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="390" height="220" as="geometry" />
        </mxCell>
        <mxCell id="mgmt_note" value="これを組織ルートに付与すれば、すべての&#xa;現行/将来のメンバーアカウントに自動適用される" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#3B48CC;" vertex="1" parent="1">
          <mxGeometry x="50" y="430" width="390" height="90" as="geometry" />
