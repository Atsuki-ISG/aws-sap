        <mxCell id="cwan" value="AWS Cloud WAN Core Network" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2E9FF;strokeColor=#8C4FFF;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="30" y="270" width="950" height="130" as="geometry" /></mxCell>
        <mxCell id="cwan1" value="• Global Network 1 つで全リージョンのコアネットワークを管理" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="50" y="300" width="900" height="18" as="geometry" /></mxCell>
        <mxCell id="cwan2" value="• セグメント (例: prod / dev / svc) を YAML ポリシーで宣言" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="50" y="325" width="900" height="18" as="geometry" /></mxCell>
        <mxCell id="cwan3" value="• 新リージョン追加 = Core Edge を 1 行 (数分) で増設" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="50" y="350" width="900" height="18" as="geometry" /></mxCell>
