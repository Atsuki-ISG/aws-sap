<mxfile host="app.diagrams.net" modified="2026-04-20T00:00:00.000Z" agent="Claude" version="24.0.0">
  <diagram id="d1" name="SAP-201">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="610" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="SAP-201: SCP Allow リスト方式 — FullAWSAccess を外すと全 API が拒否される" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="0" y="10" width="1000" height="30" as="geometry" />
        </mxCell>
        <mxCell id="default" value="既定 (Allow: FullAWSAccess)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F8E8;strokeColor=#7AA116;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="450" height="250" as="geometry" />
        </mxCell>
        <mxCell id="def_d" value="組織作成時に自動でアタッチ:&#xa;  FullAWSAccess = { &quot;Effect&quot;:&quot;Allow&quot;, &quot;Action&quot;:&quot;*&quot;, &quot;Resource&quot;:&quot;*&quot; }&#xa;&#xa;・SCP は「IAM との AND」で判定&#xa;・SCP 側で Allow が必要&#xa;・FullAWSAccess があるから IAM ポリシーの範囲内で動作&#xa;&#xa;→ 通常 OU では FullAWSAccess + ルート Deny の組合せが基本" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="410" height="200" as="geometry" />
        </mxCell>
        <mxCell id="allowlist" value="Allow リスト方式 (FullAWSAccess を外す)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFEF;strokeColor=#DD344C;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="510" y="60" width="460" height="250" as="geometry" />
        </mxCell>
        <mxCell id="al_d" value="FullAWSAccess をデタッチし、独自 Allow SCP を付与&#xa;&#xa;例:&#xa;  { &quot;Effect&quot;:&quot;Allow&quot;, &quot;Action&quot;:[&quot;ec2:*&quot;,&quot;s3:*&quot;], &quot;Resource&quot;:&quot;*&quot; }&#xa;&#xa;・SCP Allow に列挙されたアクションだけが通る&#xa;・列挙漏れは IAM で Allow しても SCP で Deny 扱い&#xa;・後から API 追加時の運用負荷大" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="530" y="100" width="420" height="200" as="geometry" />
        </mxCell>
        <mxCell id="flow" value="SCP 評価フロー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF1FF;strokeColor=#3B48CC;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="330" width="940" height="170" as="geometry" />
        </mxCell>
        <mxCell id="flow_d" value="1. 明示的 Deny (SCP) ? → 即 Deny&#xa;2. 明示的 Allow (SCP) ? → IAM 側の評価へ&#xa;3. IAM で Allow + Resource/Condition 合致? → 許可&#xa;&#xa;つまり SCP Allow に載っていない API は、IAM で Allow していても Deny&#xa;→ 「Allow リスト方式は列挙コストが高く、運用ミスで全 API 停止のリスク」" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="50" y="370" width="900" height="130" as="geometry" />
        </mxCell>
        <mxCell id="bp" value="推奨: Deny リスト方式 (FullAWSAccess はそのまま + 禁止アクションだけ Deny)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FF9900;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="520" width="940" height="70" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
