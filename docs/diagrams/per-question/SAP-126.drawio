        <mxCell id="s3_l" value="S3 バケット (2PB)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="60" y="168" width="160" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s3_p" value="Requester Pays を ON:&#xa;  GET/HEAD のデータ転送/APIコストは&#xa;  リクエスタ側の請求になる&#xa;&#xa;バケットポリシー:&#xa;  Principal: 各大学/病院アカウント" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="340" height="120" as="geometry" />
        </mxCell>
        <mxCell id="iam" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management;" vertex="1" parent="1">
          <mxGeometry x="300" y="110" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="iam_l" value="IAM Policy" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="270" y="168" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="own_note" value="・大量データの保管コストは所有者負担&#xa;・取得側は RequestPayer: requester&#xa;  を付けて取得 → 請求はリクエスタへ&#xa;&#xa;× 全コストを所有者負担 → 共同研究で不公平&#xa;× 各大学にバケットコピー → 2PB 重複で非現実" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="360" height="180" as="geometry" />
