<mxCell id="good" value="✅ 正解 A+D: awsvpc モードでタスク単位 ENI → 各タスクに SG を直接アタッチ。Task Role で最小権限 IAM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF5E0;strokeColor=#7AA116;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="355" width="960" height="46" as="geometry" />
</mxCell>
<mxCell id="bad1" value="❌ bridge モード: インスタンス単位 SG しか付与できず、同居タスク間の分離が甘い" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="415" width="470" height="50" as="geometry" />
</mxCell>
<mxCell id="bad2" value="❌ 1 つの広い IAM ロールを全タスクで共有: PCI DSS の最小権限原則に違反" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
