</mxCell>
<mxCell id="tip" value="💡 awsvpc は Fargate 必須・EC2 launch でもデフォルト推奨。タスク単位のネットワーク分離が PCI/HIPAA で標準" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F2FD;strokeColor=#3B48CC;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
