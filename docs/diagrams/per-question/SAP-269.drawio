<mxCell id="good" value="✅ 正解 A: S3→SQS→ASG EC2 で非同期疎結合。Queue 長ベースでスケール、CloudFront Invalidation で削除即時反映" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF5E0;strokeColor=#7AA116;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="290" width="960" height="50" as="geometry" />
</mxCell>
<mxCell id="bad" value="❌ Lambda: 15 分制限で合成処理が重い場合タイムアウト / ❌ 同期 EC2 直: 1 万スパイクで遅延→売上機会損失" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="350" width="960" height="50" as="geometry" />
</mxCell>
<mxCell id="tip" value="📌 削除指示への即応 = CreateInvalidation API (パスで一括無効化)。TTL 0 よりコスト効率的" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5EB;strokeColor=#FF9900;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="410" width="960" height="50" as="geometry" />
</mxCell>
<mxCell id="tip2" value="💡 「EC2 vs Lambda」の分岐点 = 実行時間 15 分と CPU/メモリ要件。画像大量合成は EC2 が無難" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F2FD;strokeColor=#3B48CC;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="470" width="960" height="50" as="geometry" />
</mxCell>
