        <mxCell id="n1" value="【Origin Group】&#10;・Primary Origin = Primary ALB&#10;・Secondary Origin = DR ALB&#10;&#10;【動作】&#10;・500/502/503/504など設定したステータスコードや&#10;  接続失敗時に CloudFront が即座に&#10;  Secondary へ切替&#10;&#10;・DNS伝搬(TTL)に依存しない → 数秒以内" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#3B48CC;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="430" height="210" as="geometry" />
        </mxCell>
        <mxCell id="rs" value="DR Region" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=11;fontStyle=1;container=1;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_region;strokeColor=#7AA116;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#7AA116;dashed=0;" vertex="1" parent="1">
