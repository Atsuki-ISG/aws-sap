        <mxCell id="n2" value="比較: ・1 つのデフォルト RT — 全 VPC が相互疎通可で監査 NG ／ ・NACL/SG のみ — パスは通っており経路制御の責任分界として不十分" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;fillColor=#FFFBE6;strokeColor=#D4AC0D;strokeWidth=1;spacing=6;rounded=1;" vertex="1" parent="1"><mxGeometry x="30" y="510" width="940" height="75" as="geometry" /></mxCell>
