<mxCell id="a18" value="PrivateLink&#10;(片方向: Consumer → Provider)" style="endArrow=classic;html=1;strokeColor=#3B48CC;strokeWidth=2;dashed=0;labelBackgroundColor=#FFFFFF;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="320" y="205" as="sourcePoint"/><mxPoint x="610" y="205" as="targetPoint"/></mxGeometry></mxCell>
<mxCell id="n19" value="◾ 要件: サードパーティ SaaS の API を プライベート に利用 (VPC Peering より疎結合)&#10;◾ 解法: AWS PrivateLink 方式&#10;  ・CIDR 衝突を気にせず利用可 (Peering と異なりルーティング不要)&#10;  ・一方向 (Consumer → Provider) のみ通信 → 攻撃面が小さい&#10;  ・Shared VPC や Transit Gateway と異なり、L7 API だけ公開できる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;strokeWidth=1;fontSize=10;fontColor=#232F3E;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;spacingRight=8;" vertex="1" parent="1"><mxGeometry x="60" y="475" width="900" height="105" as="geometry"/></mxCell>
