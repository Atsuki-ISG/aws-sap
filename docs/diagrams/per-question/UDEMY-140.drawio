<mxCell id="resp" value="リソースポリシー:&#10;{&#10;  "Effect": "Allow",&#10;  "Principal": "*",&#10;  "Action": "execute-api:Invoke",&#10;  "Condition": {&#10;    "StringEquals": {&#10;      "aws:sourceVpce": "vpce-xxx"&#10;    }&#10;  }&#10;}" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
