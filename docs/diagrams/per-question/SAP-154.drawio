<mxCell id="good" value="✅ 正解 D: スパイクする静的 = CloudFront/S3 / 重い処理 = S3 Event → SQS → Lambda の非同期分離。EC2 ASG 廃止で運用負荷激減" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF5E0;strokeColor=#7AA116;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="290" width="960" height="50" as="geometry" />
</mxCell>
<mxCell id="bad" value="❌ Beanstalk のまま: EC2 静的配信のスパイクコスト残存 / ❌ 動画を EBS に保持: スケールとコスト面で不利" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="350" width="960" height="50" as="geometry" />
</mxCell>
<mxCell id="tip" value="📌 「静的」= エッジキャッシュへ / 「非同期」= キュー + Lambda が SAP の基本方針" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5EB;strokeColor=#FF9900;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
