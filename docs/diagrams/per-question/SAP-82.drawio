<mxCell id="bad1" value="❌ イメージに資格情報を埋め込む: Git に漏れる、ローテーション不可。重大な PCI DSS 違反" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
