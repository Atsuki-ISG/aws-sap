        <mxCell id="role_l" value="OrganizationAccount&#xa;AccessRole" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
