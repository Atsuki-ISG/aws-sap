        <mxCell id="org_l" value="AWS Organizations (管理)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="90" y="165" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="central_d" value="① Organizations で中央管理アカウントを作成&#xa;② 既存の各事業部アカウントに 招待 (Invite) を送信&#xa;③ 各事業部が 招待を承諾&#xa;&#xa;請求の一元化 (Consolidated Billing):&#xa;  ・すべての事業部の請求が中央アカウントに集約&#xa;  ・ボリューム割引も組織全体で適用&#xa;&#xa;アクセスポリシー一元管理:&#xa;  ・SCP で制限を適用&#xa;  ・OrganizationAccountAccessRole で管理アクセス" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="300" height="240" as="geometry" />
        </mxCell>
        <mxCell id="ar1" value="sts:AssumeRole" style="endArrow=classic;html=1;strokeColor=#3B48CC;strokeWidth=2;fontSize=10;fontColor=#3B48CC;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="390" y="200" as="sourcePoint" />
