        <mxCell id="trustB_t" value="{&#xa;  &quot;Principal&quot;: {&quot;AWS&quot;:&#xa;    &quot;arn:aws:iam::AAAA:user/alice&quot;},&#xa;  &quot;Action&quot;: &quot;sts:AssumeRole&quot;,&#xa;  &quot;Condition&quot;: {&quot;StringEquals&quot;: {&#xa;    &quot;sts:ExternalId&quot;: &quot;xyz&quot;}}&#xa;}" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
