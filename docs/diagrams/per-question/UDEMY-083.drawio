        <mxCell id="permB_t" value="{&quot;Effect&quot;: &quot;Allow&quot;,&#xa; &quot;Action&quot;: [&quot;s3:GetObject&quot;],&#xa; &quot;Resource&quot;: &quot;arn:aws:s3:::bucket/*&quot;}&#xa;&#xa;→ 最小特権原則 (必要な操作だけ許可)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
