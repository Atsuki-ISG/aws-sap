        <mxCell id="key" value="🔑 タグ別コスト精度を最大化する方法" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FF9900;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="920" height="140" as="geometry" />
        </mxCell>
        <mxCell id="key_t" value="✓ CUR = 最も詳細なビリングデータ (1時間粒度 / リソース粒度 / タグ列)&#xa;  → 特定タグを持つリソースのコストだけを正確に抽出可能&#xa;✓ タグは 管理アカウントで「ユーザ定義タグ」として アクティベート が必須&#xa;✓ S3 + Athena + QuickSight で 可視化 / 事業部への配賦レポート&#xa;✗ Cost Explorer のみ = 日次粒度で 1年超の長期分析がしにくい&#xa;✗ Resource Groups / 手動リストは 正確な コスト集計にならない" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="55" y="450" width="900" height="110" as="geometry" />
        </mxCell>

