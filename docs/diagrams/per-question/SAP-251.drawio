        <mxCell id="pn" value="【Multi-AZ】&#10;・同期レプリ (別AZ Standby)&#10;・AZ障害時は自動フェイルオーバー&#10;・通常 30-60秒で切替&#10;&#10;【制約】&#10;・アプリ改修不可 (Aurora移行は避ける)&#10;・MySQLのまま運用継続" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#3B48CC;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="420" height="180" as="geometry" />
        </mxCell>
