        <mxCell id="rr_l" value="Cross-Region&#10;Read Replica" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#232F3E;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="198" width="150" height="30" as="geometry" />
        </mxCell>
        <mxCell id="dn" value="【Cross-Region RR】&#10;・非同期レプリ (RPO 数秒〜分)&#10;・リージョン障害時は Promote → 書込可&#10;・アプリは接続先エンドポイント変更のみ&#10;・改修なしで DR 達成" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#7AA116;" vertex="1" parent="1">
          <mxGeometry x="540" y="240" width="430" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ma" style="endArrow=classic;html=1;strokeColor=#3B48CC;strokeWidth=3;" edge="1" parent="1" source="rds_p" target="rds_s">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ma_l" value="同期 (Multi-AZ)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#3B48CC;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="ma">
          <mxGeometry x="-0.05" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="crr" style="endArrow=classic;html=1;strokeColor=#E7157B;strokeWidth=3;" edge="1" parent="1" source="rds_p" target="rr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="crr_l" value="非同期 Cross-Region RR" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#E7157B;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="crr">
          <mxGeometry x="-0.05" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="rs" style="endArrow=classic;html=1;strokeColor=#8C4FFF;strokeWidth=2;dashed=1;" edge="1" parent="1" source="rr" target="rds_p">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rs_l" value="Promote (DR時)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#8C4FFF;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="rs">
          <mxGeometry x="-0.05" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="cmp" value="✅ A=RDS Multi-AZ + Cross-Region RR: AZ障害は Multi-AZ で、リージョン障害は Cross-Region RR で対応。RDS for MySQL のまま、アプリ改修不要&#10;&#10;❌ B: Single-AZ にして複製 = 要件「単一点障害排除」に反する&#10;❌ C: Aurora 移行 = 性能は最高だが「アプリ改修を伴う大規模移行は避けたい」に反する&#10;❌ D: オンプレ DC へのバックアップ = マルチリージョン要件・自動FO要件に合わない&#10;&#10;💡 RDS Multi-AZ = HA (AZ障害対応)、Cross-Region RR = DR (リージョン障害対応)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FF9900;strokeWidth=1;fontSize=10;fontColor=#232F3E;verticalAlign=top;align=left;spacingTop=6;spacingLeft=8;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="20" y="440" width="960" height="150" as="geometry" />
        </mxCell>
