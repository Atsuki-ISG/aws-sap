</mxCell>
<mxCell id="tip2" value="💡 30 分 SLA は Streams + Lambda + Firehose buffer (max 900s) で充分達成可能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F2FD;strokeColor=#3B48CC;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
