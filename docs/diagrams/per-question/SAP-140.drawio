        </mxCell>
        <mxCell id="acq_d" value="・OU 専用 SCP で Config 許可を上書き&#xa;  (Allow config:*)&#xa;・ただし SCP は IAM &quot;Deny + Allow の AND&quot;&#xa;  → ルート Deny を OU で「上書き許可」&#xa;  するには適切な Allow SCP のみでは不可&#xa;  → Deny 条件に Account の NotIn を使う" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="520" y="215" width="430" height="120" as="geometry" />
        </mxCell>
