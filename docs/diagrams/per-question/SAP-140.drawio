        <mxCell id="title" value="SAP-140: SCP 階層 — ルートで Deny + 特定 OU/アカウントで許可 (買収アカウント例外)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="0" y="10" width="1000" height="30" as="geometry" />
        </mxCell>
        <mxCell id="root" value="Root OU (組織全体)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFEF;strokeColor=#DD344C;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="940" height="100" as="geometry" />
        </mxCell>
        <mxCell id="root_d" value="ルート SCP (すべて継承):&#xa;  Deny config:* (AWS Config 変更を禁止)&#xa;  ← Config を勝手に無効化できないセキュリティ統制" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="50" y="95" width="900" height="60" as="geometry" />
