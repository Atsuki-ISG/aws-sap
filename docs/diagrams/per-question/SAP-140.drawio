        <mxCell id="detail" value="ルート SCP 実装パターン (買収アカウント除外)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF1FF;strokeColor=#3B48CC;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="360" width="940" height="220" as="geometry" />
        </mxCell>
        <mxCell id="detail_d" value="ルート SCP:&#xa;{&#xa;  &quot;Effect&quot;: &quot;Deny&quot;,&#xa;  &quot;Action&quot;: [&quot;config:*&quot;],&#xa;  &quot;Resource&quot;: &quot;*&quot;,&#xa;  &quot;Condition&quot;: {&#xa;    &quot;StringNotEquals&quot;: {&#xa;      &quot;aws:PrincipalAccount&quot;: [&quot;買収アカウントID1&quot;, &quot;買収アカウントID2&quot;]&#xa;    }&#xa;  }&#xa;}&#xa;× OU 専用 Allow SCP だけ足しても Deny が勝つ → Deny 側の例外条件で除外が正解" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="50" y="400" width="900" height="170" as="geometry" />
        </mxCell>

