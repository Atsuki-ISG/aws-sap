<mxCell id="good" value="✅ 正解 A: コンテナ化して Fargate 実行、EventBridge cron で起動。バイナリ改修不要、アイドルコストゼロ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF5E0;strokeColor=#7AA116;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
