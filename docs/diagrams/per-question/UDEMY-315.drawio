<mxCell id="good" value="✅ EventBridge Custom Bus: 新しいマイクロサービスはルール追加のみで参加可能 → 強疎結合" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF5E0;strokeColor=#7AA116;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
