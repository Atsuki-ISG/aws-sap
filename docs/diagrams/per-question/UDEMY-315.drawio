  <mxGeometry x="20" y="440" width="960" height="60" as="geometry" />
</mxCell>
<mxCell id="tip" value="💡 Schema Registry + コード生成で各 MS の契約ずれを防止。Archive + Replay でトラブル時の再処理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F2FD;strokeColor=#3B48CC;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
