        <mxCell id="ct_desc" value="ランディングゾーンで以下が自動構築される:&#xa;・Organizations と 標準 OU (Security / Audit / Log Archive)&#xa;・AWS Config アグリゲータ / CloudTrail 組織トレイル&#xa;・IAM Identity Center 連携 / 既定ガードレール" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="400" y="85" width="540" height="70" as="geometry" />
        </mxCell>
