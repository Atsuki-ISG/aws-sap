<mxCell id="good" value="✅ 正解 A: Cognito が「メール認証」「SNS フェデレーション」をネイティブに提供。API Gateway 統合で完全マネージド認証" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF5E0;strokeColor=#7AA116;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="310" width="960" height="46" as="geometry" />
</mxCell>
<mxCell id="bad1" value="❌ IAM ユーザーで全員管理: 会員規模で破綻。IAM は AWS リソース制御用、人間ユーザーには不向き" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="370" width="470" height="50" as="geometry" />
</mxCell>
<mxCell id="bad2" value="❌ 自前認証サーバ: OAuth/OIDC 実装工数大・脆弱性リスク・運用負荷" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="510" y="370" width="470" height="50" as="geometry" />
</mxCell>
<mxCell id="tip" value="📌 Cognito UserPool vs IdentityPool: UserPool=認証(JWT発行)、IdentityPool=AWS一時認証情報発行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5EB;strokeColor=#FF9900;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
