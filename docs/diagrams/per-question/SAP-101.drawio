        <mxCell id="title" value="SAP-101: クロスアカウント S3 + KMS — 3 箇所のポリシーを揃える必要" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="0" y="10" width="1000" height="30" as="geometry" />
        </mxCell>
        <mxCell id="prod" value="制作アカウント (オブジェクト所有 + KMS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF1FF;strokeColor=#3B48CC;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="420" height="480" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
          <mxGeometry x="90" y="110" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3_l" value="S3 バケット" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="50" y="168" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s3_p" value="① バケットポリシー&#xa;  Principal:&#xa;    arn:aws:iam::OPS:role/X&#xa;  Action:&#xa;    s3:GetObject&#xa;  Resource: bucket/*" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontStyle=0;fontColor=#7AA116;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="180" height="130" as="geometry" />
        </mxCell>
        <mxCell id="kms" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="280" y="110" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="kms_l" value="KMS CMK" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="245" y="168" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="kms_p" value="② KMS キーポリシー&#xa;  Principal:&#xa;    arn:aws:iam::OPS:role/X&#xa;  Action:&#xa;    kms:Decrypt&#xa;    kms:GenerateDataKey" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontStyle=0;fontColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="240" y="200" width="190" height="130" as="geometry" />
        </mxCell>
        <mxCell id="prod_note" value="・オブジェクトは SSE-KMS で暗号化&#xa;・カスタマー管理 KMS (CMK) 必須&#xa;  (AWS 管理キーは別アカウントに共有不可)&#xa;・バケットポリシーで Get 許可だけでは&#xa;  復号できない → KMS 側も必要" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="50" y="350" width="390" height="170" as="geometry" />
        </mxCell>
        <mxCell id="ops" value="運用アカウント (Lambda 読み取り側)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F8E8;strokeColor=#7AA116;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="490" y="60" width="480" height="480" as="geometry" />
        </mxCell>
        <mxCell id="lam" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#FF9900;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" vertex="1" parent="1">
          <mxGeometry x="550" y="110" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lam_l" value="Lambda 関数" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="510" y="168" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="role" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management;" vertex="1" parent="1">
          <mxGeometry x="720" y="110" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="role_l" value="実行ロール" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="690" y="168" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="role_p" value="③ 実行ロールの IAM ポリシー&#xa;  Action:&#xa;    s3:GetObject&#xa;    kms:Decrypt&#xa;  Resource:&#xa;    arn:aws:s3:::PROD-bucket/*&#xa;    arn:aws:kms:REGION:PROD:key/ID" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="510" y="200" width="440" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ops_note" value="3 点セットが揃って初めて読み取り可能:&#xa;  ① バケットポリシー (PROD 側)&#xa;  ② KMS キーポリシー (PROD 側)&#xa;  ③ IAM ロールポリシー (OPS 側)&#xa;&#xa;× どれか1つでも欠けると AccessDenied" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="510" y="360" width="440" height="160" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="Decrypt" style="endArrow=classic;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontSize=10;fontColor=#8C4FFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="670" y="140" as="sourcePoint" />
            <mxPoint x="340" y="140" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="a2" value="GetObject" style="endArrow=classic;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontSize=10;fontColor=#8C4FFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="670" y="160" as="sourcePoint" />
            <mxPoint x="160" y="160" as="targetPoint" />
