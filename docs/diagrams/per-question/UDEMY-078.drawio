<mxCell id="r10" value="PHZ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF1FF;strokeColor=#3B48CC;strokeWidth=1;fontSize=10;fontStyle=1;fontColor=#232F3E;align=center;verticalAlign=middle;dashed=0;" vertex="1" parent="1"><mxGeometry x="520" y="220" width="100" height="40" as="geometry"/></mxCell>
