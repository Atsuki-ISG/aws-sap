  <mxGeometry x="20" y="420" width="960" height="60" as="geometry" />
</mxCell>
<mxCell id="tip" value="💡 Lambda 同時実行数の Reserved Concurrency 設定でダウンストリーム保護。バッチサイズ最大 10000 (KDS) / 10 (SQS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F2FD;strokeColor=#3B48CC;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
