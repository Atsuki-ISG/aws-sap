<mxCell id="good" value="✅ SQS が Web と Worker を完全分離。Worker 障害でもメッセージは Visibility Timeout 後に復活" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF5E0;strokeColor=#7AA116;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
