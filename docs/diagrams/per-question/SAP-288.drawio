<mxCell id="r23" value="★ 多層防御の4点セット&amp;#10;1) Gateway EP (無料・プライベート経路)&amp;#10;2) EP ポリシー (Consumer 側・持ち出し制限)&amp;#10;3) Bucket Policy: aws:sourceVpce 条件 (Provider 側)&amp;#10;4) Bucket Policy: aws:PrincipalOrgID 条件 (Org 限定)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5E8;strokeColor=#7AA116;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#232F3E;align=center;verticalAlign=middle;dashed=0;" vertex="1" parent="1"><mxGeometry x="430" y="360" width="520" height="140" as="geometry"/></mxCell>
<mxCell id="a24" value="プライベート経路" style="endArrow=classic;html=1;strokeColor=#248814;strokeWidth=2;dashed=0;labelBackgroundColor=#FFFFFF;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="340" y="200" as="sourcePoint"/><mxPoint x="430" y="175" as="targetPoint"/></mxGeometry></mxCell>
<mxCell id="n25" value="◾ 解法: Gateway EP + EP ポリシー + Bucket ポリシー (aws:sourceVpce / PrincipalOrgID) の 4 層防御&#10;  ・インターネット非経由で複数アカウントから安全にデータレイクへアクセス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=1;fontSize=10;fontColor=#232F3E;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;spacingRight=8;" vertex="1" parent="1"><mxGeometry x="40" y="530" width="920" height="60" as="geometry"/></mxCell>
