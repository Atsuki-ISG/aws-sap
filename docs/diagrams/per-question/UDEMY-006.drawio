        <mxCell id="e9" value="Inter-Region Peering" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#8C4FFF;strokeWidth=2;dashed=1;fontSize=10;fontColor=#232F3E;" edge="1" parent="1" source="tgw1" target="tgw2">
      <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n1" value="ポイント: 1 本の DX + Transit VIF から DX Gateway 経由で 最大 3 リージョンまでの TGW に接続できる。推移ルーティングで全 VPC が相互通信可能。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;fillColor=#FFFBE6;strokeColor=#D4AC0D;strokeWidth=1;spacing=6;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="310" width="960" height="50" as="geometry" /></mxCell>
        <mxCell id="n2" value="◎ 正解 B: Direct Connect + Transit VIF + DX Gateway → 各リージョン TGW 接続。推移ルーティング ○、コスト最適、安定帯域。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;fillColor=#EBF5E8;strokeColor=#7AA116;strokeWidth=1;spacing=6;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="370" width="470" height="110" as="geometry" /></mxCell>
        <mxCell id="n3" value="✕ 誤答: ・サイト間 VPN のみ (帯域不安定 / DX が要件)
・各リージョンに個別 VPN (管理負荷 / 推移なし)
・Inter-Region VPC Peering (N×N 爆発 / オンプレ接続別建て)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;fillColor=#FDEBE9;strokeColor=#DD344C;strokeWidth=1;spacing=6;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="510" y="370" width="470" height="110" as="geometry" /></mxCell>
        <mxCell id="n4" value="Transit VIF vs Private VIF vs Public VIF:
 ・Private VIF = 単一 VPC の VGW に直結 (シンプル・小規模)
 ・Transit VIF = DX GW + TGW アタッチ (複数 VPC / 複数リージョン)
 ・Public VIF = AWS パブリック IP 空間 (S3/DynamoDB 等への直接アクセス)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;fillColor=#FFFBE6;strokeColor=#D4AC0D;strokeWidth=1;spacing=6;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="492" width="960" height="90" as="geometry" /></mxCell>
