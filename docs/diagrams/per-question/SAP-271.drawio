</mxCell>
<mxCell id="tip" value="📌 API Gateway 認可タイプ: NONE / AWS_IAM / COGNITO_USER_POOLS / CUSTOM(Lambda Authorizer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5EB;strokeColor=#FF9900;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
