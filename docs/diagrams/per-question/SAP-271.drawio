</mxCell>
<mxCell id="bad1" value="❌ Cognito オーソライザー: エンドユーザー向け JWT 認証。AWS アカウント内部の IAM 認可要件に不適" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
  <mxGeometry x="20" y="350" width="470" height="50" as="geometry" />
</mxCell>
<mxCell id="bad2" value="❌ API キーのみ: 使用量制御用途。認証/認可の強度が低く、署名なしでリプレイ可能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
