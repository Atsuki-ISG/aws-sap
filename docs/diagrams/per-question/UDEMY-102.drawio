        <mxCell id="key" value="🔑 Control Tower の 予防 vs 発見 ガードレール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FF9900;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="920" height="110" as="geometry" />
        </mxCell>
        <mxCell id="key_t" value="✓ 予防的 (Preventive) = SCP でアクション拒否 → そもそも作れない (今回の要件)&#xa;✓ 発見的 (Detective) = AWS Config ルールで違反検出 → 作成後に通知 (事後検知なので今回不適)&#xa;✓ 推奨ガードレール (既定) で不足する場合、SCP を書いてカスタム予防ガードレールとして登録&#xa;✓ OU 単位で適用なので、本番 OU には別のルールを持たせられる" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=0;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="55" y="500" width="900" height="80" as="geometry" />
        </mxCell>

