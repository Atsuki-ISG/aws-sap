<mxfile host="app.diagrams.net" modified="2026-04-20T18:00:00.000Z" agent="Claude" version="24.0.0">
  <diagram id="container-capacity" name="Container Capacity Provider">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="コンテナ Capacity Provider + Spot 活用 — ECS / EKS のオートスケール基盤戦略" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="40" as="geometry" />
        </mxCell>

        <!-- ECS Side -->
        <mxCell id="ecs_grp" value="ECS — Capacity Provider 戦略" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=13;fontStyle=1;container=1;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;strokeColor=#3B48CC;fillColor=#EBF1FF;verticalAlign=top;align=left;spacingLeft=30;fontColor=#3B48CC;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="740" height="540" as="geometry" />
        </mxCell>

        <mxCell id="ecs_icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#FF9900;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ecs;" vertex="1" parent="1">
          <mxGeometry x="100" y="115" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ecs_lbl" value="ECS Cluster" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="80" y="168" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- ECS on EC2 CP -->
        <mxCell id="ecs_ec2cp" value="ECS on EC2 — Capacity Provider (ASG連携)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#FF9900;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="100" width="580" height="220" as="geometry" />
        </mxCell>
        <mxCell id="asg_icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.auto_scaling;" vertex="1" parent="1">
          <mxGeometry x="220" y="135" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ec2_icon1" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1">
          <mxGeometry x="270" y="135" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ec2_icon2" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1">
          <mxGeometry x="320" y="135" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ecs_ec2cp_text" value="• 1つの ASG = 1つの Capacity Provider (CP)&#10;• 通常 2〜3個の CP を作る:&#10;  ① OnDemand-CP  (base=N, weight=1) — 最低保証&#10;  ② Spot-CP       (base=0, weight=4) — 拡張は Spot 優先&#10;• 不足タスクで Managed Scaling が ASG をスケールアウト&#10;• 余剰インスタンスは保護 (managed termination protection)&#10;&#10;結果: 通常時の Spot 比率を 80% 程度にしつつ、最低限の OnDemand を確保。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="220" y="180" width="540" height="135" as="geometry" />
        </mxCell>

        <!-- ECS Fargate CP -->
        <mxCell id="ecs_fgcp" value="ECS Fargate — Capacity Provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#3B48CC;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="340" width="680" height="180" as="geometry" />
        </mxCell>
        <mxCell id="fg_icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#FF9900;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.fargate;" vertex="1" parent="1">
          <mxGeometry x="120" y="375" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ecs_fgcp_text" value="2 つの組み込み CP:&#10;  • FARGATE       — オンデマンド (base=ある程度確保)&#10;  • FARGATE_SPOT  — Spot (中断あり、〜70% 割引)&#10;&#10;戦略例: base=2 / FARGATE weight=1 + FARGATE_SPOT weight=4&#10;➡ 最低 2 タスクは OnDemand、追加分は Spot 優先。&#10;➡ Spot 中断は SIGTERM → 120秒後 SIGKILL、ALB から事前 deregister。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="170" y="370" width="600" height="140" as="geometry" />
        </mxCell>

        <!-- ECS cost scenario -->
        <mxCell id="ecs_cost" value="💰 コスト削減シナリオ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F8E8;strokeColor=#7AA116;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#7AA116;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="540" width="680" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ecs_cost_text" value="Dev/Stg → 100% Spot (FARGATE_SPOT)、Prod → base=N で OnDemand 確保 + 拡張のみ Spot。" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="120" y="565" width="640" height="40" as="geometry" />
        </mxCell>

        <!-- EKS Side -->
        <mxCell id="eks_grp" value="EKS — オートスケール基盤の選択" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=13;fontStyle=1;container=1;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;strokeColor=#7AA116;fillColor=#F0F8E8;verticalAlign=top;align=left;spacingLeft=30;fontColor=#7AA116;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="820" y="80" width="740" height="540" as="geometry" />
        </mxCell>

        <mxCell id="eks_icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#FF9900;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;" vertex="1" parent="1">
          <mxGeometry x="860" y="115" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eks_lbl" value="EKS Cluster" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="840" y="168" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- Cluster Autoscaler vs Karpenter -->
        <mxCell id="ca_box" value="Cluster Autoscaler (CA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#FF9900;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="100" width="290" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ca_text" value="• ASG 単位でノード追加/削除&#10;• InstanceType を ASG毎に固定&#10;• Pending Pod を 10〜30秒間隔で監視&#10;• 起動 2〜5分、シンプル・実績豊富&#10;&#10;弱点: 多種 InstanceType を扱うには&#10;ASG を多数用意する必要がある" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="955" y="135" width="265" height="140" as="geometry" />
        </mxCell>

        <mxCell id="kp_box" value="Karpenter (推奨)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7AA116;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#7AA116;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1240" y="100" width="300" height="180" as="geometry" />
        </mxCell>
        <mxCell id="kp_text" value="• ASG なし、EC2 Fleet API 直叩き&#10;• Pod の要求から最適 InstanceType 選定&#10;• Spot/OnDemand 混在、AZ 分散も自動&#10;• 起動 30〜60秒 (CA より速い)&#10;• Consolidation で詰め直し最適化&#10;&#10;➡ Spot 中断時の自動置換、ノード&#10;   多様性 (instance diversity) で耐性UP" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1255" y="135" width="275" height="140" as="geometry" />
        </mxCell>

        <!-- EKS Fargate Profile -->
        <mxCell id="eksfg_box" value="EKS Fargate プロファイル" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#3B48CC;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="300" width="600" height="160" as="geometry" />
        </mxCell>
        <mxCell id="eksfg_icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#FF9900;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.fargate;" vertex="1" parent="1">
          <mxGeometry x="960" y="335" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="eksfg_text" value="• namespace + label セレクタで対象 Pod を Fargate へ&#10;• ノード管理ゼロ、Pod 単位課金&#10;• 制約: DaemonSet 不可、特権 Pod 不可、GPU 不可、HostPath 不可、&#10;  PV は EFS のみ、Pod 起動 60〜90 秒、FARGATE_SPOT なし&#10;&#10;➡ 静的な軽量サービスや CoreDNS の隔離など、限定的に併用が現実解。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1010" y="330" width="520" height="120" as="geometry" />
        </mxCell>

        <!-- Spot interruption handling -->
        <mxCell id="spot_box" value="⚠ Spot 中断ハンドリング (rebalance recommendation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEF;strokeColor=#DD344C;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#DD344C;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="840" y="480" width="700" height="130" as="geometry" />
        </mxCell>
        <mxCell id="spot_text" value="① EC2 Rebalance Recommendation (中断前の早期警告) → CloudWatch Event&#10;② 2分前 Spot Interruption Notice → Lifecycle hook で ALB から deregister + Pod の preStop&#10;③ Karpenter / aws-node-termination-handler が cordon + drain を自動実行&#10;④ Pod は別ノードへ再スケジュール、Service の在庫切れを最小化&#10;➡ アプリは SIGTERM をきちんとハンドル + connection draining + readiness probe を必ず入れる" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="860" y="515" width="660" height="90" as="geometry" />
        </mxCell>

        <!-- Bottom selection guide -->
        <mxCell id="guide_box" value="🧭 シナリオ別 推奨構成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=1;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="1240" height="240" as="geometry" />
        </mxCell>
        <mxCell id="guide_h1" value="シナリオ" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1;fontColor=#232F3E;fillColor=#E1E4E8;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="80" y="675" width="320" height="28" as="geometry" />
        </mxCell>
        <mxCell id="guide_h2" value="推奨基盤" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1;fontColor=#232F3E;fillColor=#E1E4E8;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="400" y="675" width="320" height="28" as="geometry" />
        </mxCell>
        <mxCell id="guide_h3" value="決め手" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1;fontColor=#232F3E;fillColor=#E1E4E8;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="720" y="675" width="560" height="28" as="geometry" />
        </mxCell>

        <mxCell id="g_r1a" value="本番 Web/API、SLA 99.9%、コスト削減も" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="703" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r1b" value="ECS Fargate + FARGATE/FARGATE_SPOT 混在" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#3B48CC;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="703" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r1c" value="base=2 (OnDemand) + 拡張 Spot で安定 + 安価" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="703" width="560" height="26" as="geometry" />
        </mxCell>

        <mxCell id="g_r2a" value="バッチ / ML 学習 (中断OK、コスト最重視)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="729" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r2b" value="EKS + Karpenter (Spot 100%) / ECS×EC2 Spot CP" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#7AA116;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="729" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r2c" value="Spot 70% 割引、Karpenter で多様な InstanceType" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="729" width="560" height="26" as="geometry" />
        </mxCell>

        <mxCell id="g_r3a" value="既存 EKS、ASG 管理を辞めたい" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="755" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r3b" value="Cluster Autoscaler → Karpenter 移行" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#7AA116;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="755" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r3c" value="ASG 不要、起動高速、Consolidation で密度UP" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="755" width="560" height="26" as="geometry" />
        </mxCell>

        <mxCell id="g_r4a" value="Dev / Stg 環境 (夜間停止OK)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="781" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r4b" value="ECS Fargate 100% Spot / EKS Karpenter Spot" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#DD344C;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="781" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r4c" value="中断許容、SLA 不要、コスト最優先" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="781" width="560" height="26" as="geometry" />
        </mxCell>

        <mxCell id="g_r5a" value="GPU 推論 / 特殊インスタンス" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="807" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r5b" value="EC2 起動タイプ必須 (ECS×EC2 / EKS×EC2)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#FF9900;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="807" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_r5c" value="Fargate は GPU/特殊HW 不可" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="807" width="560" height="26" as="geometry" />
        </mxCell>

        <mxCell id="g_note" value="📌 試験Tips: 「OnDemand 最低保証 + 拡張 Spot」→ Capacity Provider strategy + base/weight。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontStyle=2;fontColor=#FF9900;" vertex="1" parent="1">
          <mxGeometry x="80" y="838" width="1200" height="28" as="geometry" />
        </mxCell>

        <!-- Bottom-right marker -->
        <mxCell id="note_box" value="📌 4象限選定マトリクス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1320" y="640" width="240" height="240" as="geometry" />
        </mxCell>
        <mxCell id="note_text" value="基盤 × Spot活用&#10;&#10;ECS Fargate:&#10;  base + FARGATE_SPOT&#10;ECS EC2:&#10;  ASG連携 CP 複数&#10;EKS:&#10;  Karpenter で diversity&#10;EKS Fargate:&#10;  限定併用&#10;&#10;基本: OnDemand 最低保証&#10;     + 拡張 Spot" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1335" y="675" width="220" height="200" as="geometry" />
        </mxCell>

