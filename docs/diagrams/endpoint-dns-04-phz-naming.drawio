        <!-- VPC B -->
        <mxCell id="vpc_b" value="Workload VPC B&#10;(開発 - acc 222222222222)" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=10;fontStyle=1;container=1;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_vpc;strokeColor=#248814;fillColor=#FFFFFF;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="920" y="340" width="280" height="220" as="geometry" />
        </mxCell>

        <mxCell id="vpc_b_ec2" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1">
          <mxGeometry x="960" y="380" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="vpc_b_alb" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_load_balancing;" vertex="1" parent="1">
          <mxGeometry x="1080" y="380" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="vpc_b_query" value="api.internal.example.com&#10;→ ALB の私有 IP&#10;(同じ PHZ を共有)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#248814;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="930" y="450" width="260" height="50" as="geometry" />
        </mxCell>

        <mxCell id="vpc_b_cidr" value="enableDnsSupport ✅&#10;enableDnsHostnames ✅" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#FF9900;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="930" y="510" width="260" height="40" as="geometry" />
        </mxCell>

        <!-- VPC C -->
        <mxCell id="vpc_c" value="Sandbox VPC C&#10;(個人 - acc 333333333333)" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=10;fontStyle=1;container=1;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_vpc;strokeColor=#7AA116;fillColor=#FFFFFF;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="1220" y="340" width="300" height="220" as="geometry" />
        </mxCell>

        <mxCell id="vpc_c_ec2" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1">
          <mxGeometry x="1340" y="380" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="vpc_c_query" value="❌ db.internal.example.com&#10;→ NXDOMAIN (関連付けなし)&#10;セキュリティ境界として有効" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#DD344C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1230" y="450" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="vpc_c_cidr" value="PHZ 関連付け なし → 解決不可" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#DD344C;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1230" y="510" width="280" height="20" as="geometry" />
        </mxCell>

        <!-- Arrows: PHZ → VPC associations -->
        <mxCell id="arr_phz_a" style="endArrow=classic;html=1;strokeColor=#8C4FFF;strokeWidth=2;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="phz_main" target="vpc_a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr_phz_b" style="endArrow=classic;html=1;strokeColor=#8C4FFF;strokeWidth=2;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="phz_main" target="vpc_b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Bottom: Naming Design + Decision ===== -->
        <mxCell id="naming_box" value="📛 名前解決設計のベストプラクティス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="600" width="900" height="220" as="geometry" />
        </mxCell>

        <mxCell id="naming_text" value="✅ ドメイン階層を環境/サービスで切る&#10;　・本番: prod.internal.example.com&#10;　・ステージ: stg.internal.example.com&#10;　・サービス: api.prod.internal.example.com&#10;&#10;✅ AWS 予約名を避ける (amazonaws.com / cloudfront.net など)&#10;✅ Public Hosted Zone と Private Hosted Zone でルートドメインを共有可 (Split-horizon)&#10;✅ ALB/NLB/RDS は CNAME で抽象化 → エンドポイント変更時のクライアント影響なし&#10;&#10;❌ アンチパターン&#10;　・VPC 毎に別 PHZ を作って同じレコードを多重管理 → DRY違反&#10;　・ec2-x-x-x-x.compute.amazonaws.com を直接参照 → IP 変更で破綻&#10;　・DHCP Options Set でオンプレDNSを直接指定 → AmazonProvidedDNS バイパス&#10;　・PHZと同名Public HZ で対応レコードに齟齬 → 経路によって挙動が変わる罠" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="630" width="860" height="190" as="geometry" />
        </mxCell>

        <!-- Decision Flow -->
        <mxCell id="dec_box" value="🧭 試験で迷ったときの判断フロー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="600" width="560" height="220" as="geometry" />
        </mxCell>

        <mxCell id="dec_text" value="• 「VPC 内部だけで解決したい」&#10;  → Private Hosted Zone を VPC に関連付け&#10;&#10;• 「複数アカウントの VPC で同じ PHZ」&#10;  → create-vpc-association-authorization &#10;  → associate-vpc-with-hosted-zone&#10;&#10;• 「内部と外部で同じドメインで違う応答」&#10;  → Split-horizon DNS (PHZ + Public HZ)&#10;&#10;• 「PHZ レコードが解決できない」&#10;  → enableDnsSupport / enableDnsHostnames を確認&#10;  → DHCP Options Set がカスタムなら戻す&#10;&#10;• 「Resolver Rule を全VPC で共有」&#10;  → AWS RAM 共有 (Rule + Outbound Endpoint)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="990" y="630" width="540" height="190" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
