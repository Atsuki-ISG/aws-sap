        <mxCell id="vpc_a_query" value="db.internal.example.com&#10;→ RDS の私有 IP&#10;(PHZ 関連付け済み)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#248814;fontStyle=1;" vertex="1" parent="1">
