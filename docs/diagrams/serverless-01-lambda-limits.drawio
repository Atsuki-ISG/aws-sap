        <!-- Bottom note -->
        <mxCell id="arch_note" value="📌 ハイブリッド設計のベストプラクティス: Lambda で 95% を低コスト処理 → 残り 5% (タイムアウト/メモリ超過/外部API遅延) を DLQ → Fargate へ振り分ける。&#10;Lambda Destinations (onSuccess / onFailure) を使えば DLQ 不要で EventBridge / SNS / SQS / Lambda へ直接ルーティング可能 (非同期呼び出しのみ)。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="1480" height="40" as="geometry" />
        </mxCell>

        <!-- Bottom-right key takeaway -->
        <mxCell id="key_takeaway" value="📌 ワークロード→サービス選定&#10;短時間・イベント駆動 = Lambda / 長時間バッチ = Step Functions or Fargate / 常時稼働 = Fargate or EC2 / GPU・特殊HW = EC2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#FF9900;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#FFFFFF;verticalAlign=middle;align=center;" vertex="1" parent="1">
