        </mxCell>
        <mxCell id="limit3" value="💾 /tmp ストレージ&#10;512 MB (デフォルト)&#10;最大 10 GB に拡張可" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=1;fontSize=11;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="560" y="115" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="limit4" value="📦 ペイロードサイズ&#10;同期: 6 MB / 非同期: 256 KB&#10;大きい場合は S3 経由" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=1;fontSize=11;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="limit5" value="🚦 同時実行数&#10;リージョン default 1,000&#10;Reserved/Provisioned で固定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=1;fontSize=11;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="210" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="limit6" value="📂 デプロイパッケージ&#10;Zip: 50MB (圧縮)/250MB (展開)&#10;Container Image: 10 GB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=1;fontSize=11;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="520" y="210" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="limit_note" value="📌 制限超過時の選択肢:&#10;・15分超え → Step Functions で分割 / Fargate / EC2 ワーカー&#10;・10GBメモリ超え → Fargate (vCPU 16/120GB まで) / EC2&#10;・大ペイロード → S3に置いて Pre-signed URL or Event参照&#10;・1000同時実行超え → クォータ引上げ申請 or Reserved Concurrency 配分" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="295" width="680" height="115" as="geometry" />
        </mxCell>

        <!-- ====== 判断フロー ====== -->
        <mxCell id="flow_box" value="判断フロー — Lambda / Fargate / EC2 のどれを選ぶ？" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF1FF;strokeColor=#3B48CC;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
