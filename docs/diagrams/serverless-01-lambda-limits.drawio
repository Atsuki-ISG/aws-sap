        <!-- Limit cards -->
        <mxCell id="limit1" value="⏱ 実行時間&#10;最大 15分&#10;(同期/非同期共通)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=1;fontSize=11;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
