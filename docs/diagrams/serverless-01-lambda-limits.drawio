        <mxCell id="limit2" value="🧠 メモリ&#10;128 MB - 10,240 MB&#10;(1MB単位、CPU比例)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=1;fontSize=11;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
