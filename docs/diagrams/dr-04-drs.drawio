        <!-- ===== Migration vs DR Notes ===== -->
        <mxCell id="mig_box" value="🔁 DRS と MGN（Application Migration Service）の関係" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#0D47A1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1120" y="495" width="440" height="200" as="geometry" />
        </mxCell>
        <mxCell id="mig_text" value="• 両者は CloudEndure 由来、ほぼ同じレプリ技術&#10;&#10;◆ DRS = 継続的レプリで「いつでも復旧可能」&#10;　 → DR用途・繰り返しテスト・ランサム対策&#10;&#10;◆ MGN = 移行を完了してEC2 cutover&#10;　 → 1回限りの移行が目的&#10;&#10;💡 試験Tips:&#10;　・「オンプレ → AWS で DR 構築」→ DRS&#10;　・「オンプレ → AWS へ最小ダウン移行」→ MGN&#10;　・「クロスRegion DR」→ DRS or Aurora Global" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="525" width="410" height="165" as="geometry" />
        </mxCell>

        <!-- ===== 📌 RTO/RPO Cheat Sheet ===== -->
        <mxCell id="cheat_box" value="📌 RTO/RPO別 戦略選定表（DRS視点）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="735" width="1520" height="140" as="geometry" />
        </mxCell>
        <mxCell id="cheat_text" value="◆ オンプレ → AWS DR、RPO秒・RTO分 → AWS DRS（Pilot Light相当のコストで高速復旧、CloudEndure後継）&#10;◆ オンプレ → AWS への一回限り移行 → AWS MGN（Migration完了後はDRSへ切替も可能）&#10;◆ AWS内 EC2 → 別Regionの DR → DRS でも可能（リージョン間レプリ）&#10;◆ Tier-0 ミッションクリティカル DBなら → Aurora Global Database / DynamoDB Global Tables（RPO &lt; 1s）&#10;&#10;⚠️ 引っかけ:「オンプレのVM/物理サーバーをAWSへDR」「VM管理者がAWS不慣れ」→ 設定簡単・対応OS広い AWS DRS 一択&#10;⚠️ AWS Backup は『バックアップ』であり継続レプリではない → RPO 秒の要件は DRS でないと達成不能&#10;💡 暗記カード:『DRS = 継続レプリ + 低コスト保管 + フェイルオーバー時のみEC2起動』" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="60" y="765" width="1490" height="105" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
