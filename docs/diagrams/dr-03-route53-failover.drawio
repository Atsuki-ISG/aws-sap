        <!-- 📌 RTO/RPO 別 戦略選定表 -->
        <mxCell id="cheat_box" value="📌 RTO/RPO別 戦略選定表（Route 53 視点）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1110" y="610" width="450" height="270" as="geometry" />
        </mxCell>
        <mxCell id="cheat_text" value="◆ RTO 数分許容（Active-Passive）&#10;　→ R53 Failover + ELB Health Check + Alias&#10;&#10;◆ RTO ほぼ0（Active-Active）&#10;　→ R53 Latency / Geolocation + 各Region同等構成&#10;&#10;◆ TTL 設計&#10;　→ Failover用は 60秒以下（伝播優先）&#10;　→ ただしDNSキャッシュ依存に注意&#10;&#10;◆ HC 失敗時間 = 30s × 3 = 約90秒&#10;　＋ TTL = フェイルオーバー実所要時間&#10;&#10;💡 暗記: 「DNSフェイルオーバーは数分単位」&#10;　 即時を求めるなら GLB / ALB Cross-Region" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1130" y="640" width="420" height="235" as="geometry" />
        </mxCell>

