        <!-- Peering connections (full mesh) -->
        <mxCell id="p_ab" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#3B48CC;strokeWidth=2;" edge="1" parent="1" source="p_vpc_a" target="p_vpc_b">
          <mxGeometry relative="1" as="geometry" />
