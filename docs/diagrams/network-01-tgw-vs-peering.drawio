        <mxCell id="p_bc" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#3B48CC;strokeWidth=2;" edge="1" parent="1" source="p_vpc_b" target="p_vpc_c">
          <mxGeometry relative="1" as="geometry" />
