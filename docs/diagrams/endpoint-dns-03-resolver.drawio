<mxfile host="app.diagrams.net" modified="2026-04-20T18:00:00.000Z" agent="Claude" version="24.0.0">
  <diagram id="route53-resolver" name="Route 53 Resolver Inbound/Outbound">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Route 53 Resolver — Inbound / Outbound 方向と双方向ハイブリッドDNS" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="40" as="geometry" />
        </mxCell>

        <!-- ===== AWS Cloud (Center) ===== -->
        <mxCell id="aws_cloud" value="AWS Cloud" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=1;container=1;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;strokeColor=#232F3E;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="700" height="540" as="geometry" />
        </mxCell>

        <mxCell id="net_vpc" value="Network/Shared VPC (10.0.0.0/16)" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=11;fontStyle=1;container=1;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_vpc;strokeColor=#248814;fillColor=#E9F3E6;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="520" y="120" width="660" height="480" as="geometry" />
        </mxCell>

        <!-- Inbound Resolver -->
        <mxCell id="inbound" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.route_53;" vertex="1" parent="1">
          <mxGeometry x="540" y="170" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="inbound_l" value="Inbound Resolver Endpoint&#10;(ENI × 2AZ 以上)&#10;listener IP: 10.0.1.10 / 10.0.2.10" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#3B48CC;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="180" width="270" height="40" as="geometry" />
        </mxCell>

        <mxCell id="inbound_use" value="📥 用途&#10;・オンプレ DNS → AWS の Private Hosted Zone を解決&#10;・オンプレ DNS → VPC 内ホスト名 (ec2.internal等) を解決&#10;・オンプレ → Interface VPC Endpoint の Private DNS 解決&#10;  (これが無いとオンプレからの S3/KMS/SSM 名前解決が破綻)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;strokeWidth=1;fontSize=10;fontColor=#232F3E;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="240" width="620" height="80" as="geometry" />
        </mxCell>

        <!-- Outbound Resolver -->
        <mxCell id="outbound" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.route_53;" vertex="1" parent="1">
          <mxGeometry x="540" y="350" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="outbound_l" value="Outbound Resolver Endpoint&#10;(ENI × 2AZ 以上)&#10;forwarder IP: 10.0.1.20 / 10.0.2.20" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#FF9900;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="360" width="270" height="40" as="geometry" />
        </mxCell>

        <mxCell id="outbound_use" value="📤 用途 + Resolver Rule&#10;・AWS リソース → 社内 DNS (corp.example.com) を解決&#10;・Forward Rule: corp.example.com → 192.168.10.53 (オンプレDNS)&#10;・FORWARD vs SYSTEM (デフォルトに戻す) vs RECURSIVE&#10;・RAM 共有でルールを 他アカウント/VPC へ展開" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9900;strokeWidth=1;fontSize=10;fontColor=#232F3E;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="420" width="620" height="80" as="geometry" />
        </mxCell>

        <!-- AmazonProvidedDNS -->
        <mxCell id="awsdns" value=".2 AmazonProvidedDNS&#10;(VPC CIDR + 2)&#10;PHZ / EC2 内部FQDN を解決" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#248814;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="930" y="170" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="phz" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.route_53;" vertex="1" parent="1">
          <mxGeometry x="950" y="520" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="phz_l" value="Private Hosted Zone&#10;internal.example.com" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1010" y="525" width="170" height="40" as="geometry" />
        </mxCell>

        <!-- ===== On-Premises ===== -->
        <mxCell id="onprem" value="オンプレミス データセンター" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=1;container=1;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_corporate_data_center;strokeColor=#666666;fillColor=#F5F5F5;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="380" height="540" as="geometry" />
        </mxCell>

        <mxCell id="op_dns" value="社内 DNS&#10;corp.example.com&#10;192.168.10.53" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="180" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="op_client" value="社内クライアント / オンプレApp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="380" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="op_note" value="📌 conditional forwarder の設定&#10;・*.aws.example.com&#10;  → 10.0.1.10 (Inbound Resolver)&#10;・他は通常のキャッシュ/再帰&#10;&#10;📌 オンプレからの解決経路&#10;Client → 社内DNS → Inbound Resolver&#10;  → R53 PHZ / Amazon DNS / EP の Private DNS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;strokeWidth=1;fontSize=10;fontColor=#232F3E;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="340" height="140" as="geometry" />
        </mxCell>

        <!-- DX/VPN -->
        <mxCell id="dx" value="Direct Connect / VPN&#10;(プライベートIPで疎通)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#232F3E;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="455" y="290" width="40" height="120" as="geometry" />
        </mxCell>

        <!-- ===== Inbound flow arrow (on-prem → AWS) ===== -->
        <mxCell id="arr_in" value="📥 Inbound&#10;オンプレDNS → 10.0.1.10" style="endArrow=classic;html=1;strokeColor=#3B48CC;strokeWidth=3;fontSize=10;fontStyle=1;fontColor=#3B48CC;" edge="1" parent="1" source="op_dns" target="inbound">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Outbound flow arrow (AWS → on-prem) ===== -->
        <mxCell id="arr_out" value="📤 Outbound&#10;Resolver Rule で転送" style="endArrow=classic;html=1;strokeColor=#FF9900;strokeWidth=3;fontSize=10;fontStyle=1;fontColor=#FF9900;" edge="1" parent="1" source="outbound" target="op_dns">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Internal arrows in VPC -->
        <mxCell id="arr_phz" style="endArrow=classic;html=1;strokeColor=#248814;strokeWidth=2;dashed=1;" edge="1" parent="1" source="awsdns" target="phz">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Bottom: DHCP Options Set ===== -->
        <mxCell id="dhcp_box" value="🔧 DHCP Options Set との関係 (重要)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="900" height="180" as="geometry" />
        </mxCell>

        <mxCell id="dhcp_text" value="VPC 内 EC2 の /etc/resolv.conf は DHCP Options Set で決まる：&#10;&#10;【パターンA】domain-name-servers = AmazonProvidedDNS （デフォルト・推奨）&#10;  → Amazon DNS (.2) が解決 → PHZ / EC2内部FQDN / EP の Private DNS が透過的に効く&#10;  → 社内 DNS が必要なドメインは Outbound Resolver + Resolver Rule で転送&#10;&#10;【パターンB】domain-name-servers = 192.168.10.53 (オンプレDNSを直接指定)&#10;  → ❌ AmazonProvidedDNS をバイパスするため PHZ / EC2 内部FQDN / EP の Private DNS が解決できない&#10;  → ハイブリッド構成では避けるべき&#10;&#10;✅ 正解パターン: AmazonProvidedDNS をそのまま使い、Outbound Resolver Rule で社内ドメインだけ転送" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="670" width="860" height="150" as="geometry" />
        </mxCell>

        <!-- ===== Decision Flow ===== -->
        <mxCell id="dec_box" value="🧭 試験で迷ったときの判断フロー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="640" width="560" height="180" as="geometry" />
        </mxCell>

        <mxCell id="dec_text" value="• 「オンプレ から AWS の PHZ を引きたい」&#10;  → Inbound Resolver Endpoint&#10;&#10;• 「AWS から オンプレ社内DNS を引きたい」&#10;  → Outbound Resolver Endpoint + Forward Rule&#10;&#10;• 「双方向ハイブリッドDNS」&#10;  → Inbound + Outbound 両方を Network VPC に配置&#10;&#10;• 「複数 VPC で同じ Resolver Rule を共有」&#10;  → Resolver Rule を RAM で共有 (中央 VPC で1セット)&#10;&#10;• 「DHCP Options Set を変えるべきか」&#10;  → 基本は AmazonProvidedDNS のまま (Resolver Rule で転送)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="990" y="670" width="540" height="150" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
