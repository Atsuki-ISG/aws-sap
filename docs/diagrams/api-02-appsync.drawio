          <mxGeometry x="1350" y="240" width="120" height="30" as="geometry" />
        </mxCell>

        <!-- Pipeline Resolver illustration -->
        <mxCell id="pipeline_box" value="🔗 Pipeline Resolver — 1クエリで複数DSを連結" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7AA116;strokeWidth=1;dashed=1;fontSize=11;fontStyle=1;fontColor=#1B660F;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="840" y="290" width="680" height="170" as="geometry" />
        </mxCell>
        <mxCell id="pipeline_text" value="例: query getDashboard {&#10;   user(id: $id) → DynamoDB&#10;   posts(authorId: $id) → DynamoDB&#10;   recommendations → Lambda → 外部API&#10;   trending → OpenSearch&#10;}&#10;&#10;→ 従来REST: 4回のラウンドトリップ&#10;→ AppSync: 1回でまとめて取得 (over/under-fetch解消)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="860" y="315" width="640" height="135" as="geometry" />
        </mxCell>

