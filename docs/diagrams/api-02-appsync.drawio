          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Bottom: Use cases ===== -->
        <mxCell id="uc_box" value="AppSync を選ぶ典型ユースケース" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=1;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="980" height="270" as="geometry" />
        </mxCell>
        <mxCell id="uc_text" value="① モバイルアプリのオフライン同期&#10;   Amplify DataStore でローカルDBと自動同期。電波回復時に Conflict resolution 実行。&#10;&#10;② リアルタイム協調編集 / チャット / 通知&#10;   Subscription で他クライアントの Mutation を即時 push。WebSocket 管理は AppSync 任せ。&#10;&#10;③ 1画面に複数データソース集約 (BFF不要)&#10;   ダッシュボード等で User/Post/Trending を 1クエリで取得 → API Gateway+Lambda+REST 集約より工数大幅減。&#10;&#10;④ きめ細かいフィールドレベル認可&#10;   @auth ディレクティブ (Amplify) や Resolver で「owner だけが update 可」等を Schema に宣言的に記述。&#10;&#10;⑤ Pub/Sub バックエンド&#10;   AppSync Events / Subscription による fan-out。MQTT (IoT Core) との使い分けは「クライアントがWebか/IoTデバイスか」。" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="80" y="535" width="940" height="225" as="geometry" />
        </mxCell>

        <!-- ===== Selection Matrix (right) ===== -->
        <mxCell id="mat_box" value="📌 サービス選定マトリクス — AppSync vs API Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFD5;strokeColor=#FF9900;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#232F3E;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="500" width="480" height="270" as="geometry" />
        </mxCell>
        <mxCell id="mat_text" value="✓ AppSync を選ぶ&#10;• モバイル/Web で「リアルタイム同期」&#10;  + 「オフライン対応」&#10;• 1画面に複数DSをまとめる BFF を作りたくない&#10;• GraphQL を使いたい&#10;• Schema 駆動で型安全に開発したい&#10;&#10;✗ AppSync を避ける&#10;• B2B REST API公開 (API Key/Usage Plan必要)&#10;  → API Gateway REST&#10;• 既存 REST 資産を再利用&#10;  → API Gateway REST/HTTP&#10;• 単純な CRUD のみ / GraphQL不要&#10;  → API Gateway HTTP + Lambda&#10;• IoT MQTT 通信&#10;  → IoT Core" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1080" y="535" width="450" height="225" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
