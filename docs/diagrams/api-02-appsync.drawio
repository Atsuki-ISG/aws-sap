        <mxCell id="schema_text" value="type Post {&#10;  id: ID!&#10;  title: String&#10;  author: User @hasOne&#10;  comments: [Comment]&#10;}&#10;type Subscription {&#10;  onCreatePost: Post&#10;}" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;fontColor=#232F3E;fontFamily=Courier New;" vertex="1" parent="1">
